{
  "name": "atlas",
  "version": "0.1.0",
  "description": "Atlas — a Layer-3 Moku consumer demo app (the Tracker redesign) on @moku-labs/web (client / island layer) + @moku-labs/worker (Cloudflare server: D1 / KV / R2 / Queues / Durable Objects).",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "bun": ">=1.3.14"
  },
  "dependencies": {
    "@moku-labs/web": "2.2.0",
    "@moku-labs/worker": "0.15.0",
    "preact": "10.29.2",
    "preact-render-to-string": "6.7.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.4",
    "@arethetypeswrong/core": "0.18.4",
    "@axe-core/playwright": "4.12.1",
    "@biomejs/biome": "2.5.1",
    "@cloudflare/workers-types": "4.20260625.1",
    "@playwright/test": "1.61.1",
    "@types/bun": "1.3.14",
    "@vitest/coverage-istanbul": "4.1.9",
    "eslint": "9.39.3",
    "eslint-config-biome": "2.1.3",
    "eslint-plugin-jsdoc": "63.0.8",
    "eslint-plugin-sonarjs": "4.0.0",
    "eslint-plugin-unicorn": "63.0.0",
    "globals": "17.7.0",
    "jiti": "2.7.0",
    "lefthook": "2.1.9",
    "playwright": "1.61.1",
    "publint": "0.3.21",
    "tsdown": "0.22.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0",
    "vitest": "4.1.9",
    "wrangler": "4.103.0"
  },
  "scripts": {
    "build": "bun run scripts/build.ts",
    "build:worker": "wrangler deploy --dry-run --outdir dist/worker",
    "dev": "bun scripts/dev.ts",
    "deploy": "bun scripts/deploy.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check . && eslint .",
    "lint:fix": "biome check --write . && eslint --fix .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:coverage": "vitest run --project unit --project integration --coverage",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "test:e2e:update:linux": "docker run --rm -v $(pwd):/work -w /work mcr.microsoft.com/playwright:v1.61.1-noble bunx playwright test --update-snapshots"
  }
}
