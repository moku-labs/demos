{
  "name": "atlas",
  "version": "0.1.0",
  "description": "Atlas — a Layer-3 Moku consumer demo app (the Tracker redesign) on @moku-labs/web (client / island layer) + @moku-labs/worker (Cloudflare server: D1 / KV / R2 / Queues / Durable Objects).",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "bun": ">=1.3.14"
  },
  "dependencies": {
    "@moku-labs/web": "2.0.0",
    "@moku-labs/worker": "0.10.0",
    "preact": "10.29.2",
    "preact-render-to-string": "6.7.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.3",
    "@arethetypeswrong/core": "0.18.3",
    "@biomejs/biome": "2.4.16",
    "@cloudflare/workers-types": "4.20260617.1",
    "@types/bun": "1.3.14",
    "@vitest/coverage-istanbul": "4.0.18",
    "eslint": "9.39.3",
    "eslint-config-biome": "2.1.3",
    "eslint-plugin-jsdoc": "62.6.0",
    "eslint-plugin-sonarjs": "4.0.0",
    "eslint-plugin-unicorn": "63.0.0",
    "globals": "17.4.0",
    "jiti": "2.6.1",
    "lefthook": "2.1.1",
    "publint": "0.3.21",
    "tsdown": "0.22.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.58.0",
    "vitest": "4.0.18",
    "wrangler": "4.102.0"
  },
  "scripts": {
    "build": "bun run scripts/build.ts",
    "build:worker": "wrangler deploy --dry-run --outdir dist/worker",
    "dev": "bun scripts/dev.ts",
    "deploy": "bun scripts/deploy.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check . && eslint .",
    "lint:fix": "biome check --write . && eslint --fix .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:coverage": "vitest run --project unit --project integration --coverage"
  }
}
