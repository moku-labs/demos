{
  "main": "src/cloudflare/worker.ts",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": "dist/client",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "name": "tracker",
  "compatibility_date": "2026-06-17",
  "kv_namespaces": [
    {
      "binding": "BOARDS_KV"
    }
  ],
  "r2_buckets": [
    {
      "binding": "ATTACHMENTS",
      "bucket_name": "tracker-attachments"
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "tracker-db",
      "migrations_dir": "db/migrations"
    }
  ],
  "queues": {
    "producers": [
      {
        "queue": "tracker-activity",
        "binding": "ACTIVITY_QUEUE"
      }
    ],
    "consumers": [
      {
        "queue": "tracker-activity"
      }
    ]
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "BOARD",
        "class_name": "BoardChannel"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": [
        "BoardChannel"
      ]
    }
  ]
}